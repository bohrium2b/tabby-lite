# Example environment variables for local development or Render
# Copy to `.env` and fill values (do NOT commit secrets to git)

# Django secret key (use a long random string)
DJANGO_SECRET_KEY=replace_me_with_a_strong_secret

# Tabbycat API root URL (the app expects an API endpoint here)
TABBY_ROOT=https://example.com/api/v1/tournaments/YourTournament

# Tabbycat authentication token (if required by your TABBY_ROOT)
TABBY_AUTHENTICATION_TOKEN=replace_me_with_token

# Postgres connection string for local development
# Example: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@localhost:5432/tabby_lite
